# 複製這個檔案改名為 .env，填入你的真實 key

# 免費！去 https://aistudio.google.com/apikey 用 Google 帳號登入就能免費建立
GEMINI_API_KEY=your_key_here

# EAP 平台（勾選「使用 EAP 平台回答」時才會用到，三個都要填）
# BASE_URL 留空會自動退回官方預設端點 https://cloud.geminidata.com/api/portal/api10
EAP_API_BASE_URL=
# 專案 ID，在專案網址列找得到：.../portal/project/<這一段>
# 這個變數程式一定會讀（見 src/eap_client.py），少填會連不上平台
EAP_PROJECT_ID=
# 專案 Token：EAP 後台「管理專案」→「通證管理」→「新增通證」
EAP_API_KEY=
