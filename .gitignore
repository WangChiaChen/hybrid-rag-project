venv/
__pycache__/
*.pyc
.env
# vector_db/ 刻意進版控：Streamlit Cloud 只會從 repo 拉檔案，
# 知識庫不在裡面的話部署出去的 app 就是空的（使用者也沒辦法自己重跑解析）。
# 只有 2.2MB，而且是 demo 專案不是正式系統，值得這個取捨。
pages/
outputs/*.docx
outputs/*.json
uploads_temp/
.DS_Store
downloads/

# 匯出的產生物，都能用腳本重跑出來，不進版控（進了反而容易拿到過期的版本）
graph_import.csv            # export_graph_csv.py --format flat
eap_graph_precise.csv       # export_graph_csv.py（給 EAP New Flow 匯入）
outputs/transcript_*.pdf    # transcript_to_pdf.py（給 EAP Upload file 用），來源 .txt 有進版控

# Claude Code 本機工具設定（非共用）
.claude/settings.local.json

# Office 暫存／鎖定檔
~$*
*.bak.pptx
